version: 1
project:
  name: angstrem-content-factory
  description: Стартовый комплект конфигурации для развертывания контент-завода Ангстрем в Dockhost.

environment:
  variables:
    POSTGRES_USER: ${POSTGRES_USER}
    POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    POSTGRES_DB: ${POSTGRES_DB}
    REDIS_PASSWORD: ${REDIS_PASSWORD}
    DIRECTUS_VERSION: ${DIRECTUS_VERSION}
    DIRECTUS_PORT: ${DIRECTUS_PORT}
    DIRECTUS_PUBLIC_URL: ${DIRECTUS_PUBLIC_URL}
    DIRECTUS_CORS_ORIGIN: ${DIRECTUS_CORS_ORIGIN}
    DIRECTUS_SECRET: ${DIRECTUS_SECRET}
    DIRECTUS_ADMIN_EMAIL: ${DIRECTUS_ADMIN_EMAIL}
    DIRECTUS_ADMIN_PASSWORD: ${DIRECTUS_ADMIN_PASSWORD}
    DIRECTUS_DB_NAME: ${DIRECTUS_DB_NAME}
    DIRECTUS_DB_USER: ${DIRECTUS_DB_USER}
    DIRECTUS_DB_PASSWORD: ${DIRECTUS_DB_PASSWORD}
    N8N_VERSION: ${N8N_VERSION}
    N8N_PORT: ${N8N_PORT}
    N8N_HOST: ${N8N_HOST}
    N8N_WEBHOOK_URL: ${N8N_WEBHOOK_URL}
    N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
    N8N_DB_NAME: ${N8N_DB_NAME}
    N8N_DB_USER: ${N8N_DB_USER}
    N8N_DB_PASSWORD: ${N8N_DB_PASSWORD}
    N8N_WORKER_CONCURRENCY: ${N8N_WORKER_CONCURRENCY}
    OPENWEBUI_VERSION: ${OPENWEBUI_VERSION}
    OPENWEBUI_PORT: ${OPENWEBUI_PORT}
    OPENWEBUI_SECRET_KEY: ${OPENWEBUI_SECRET_KEY}
    LITELLM_PORT: ${LITELLM_PORT}
    LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
    LITELLM_DB_NAME: ${LITELLM_DB_NAME}
    LITELLM_DB_USER: ${LITELLM_DB_USER}
    LITELLM_DB_PASSWORD: ${LITELLM_DB_PASSWORD}
    LITELLM_UI_USERNAME: ${LITELLM_UI_USERNAME}
    LITELLM_UI_PASSWORD: ${LITELLM_UI_PASSWORD}
    OPENAI_API_KEY: ${OPENAI_API_KEY}
    ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
    GEMINI_API_KEY: ${GEMINI_API_KEY}
    GIGACHAT_API_KEY: ${GIGACHAT_API_KEY}
    YANDEXGPT_API_KEY: ${YANDEXGPT_API_KEY}
    MINIO_ROOT_USER: ${MINIO_ROOT_USER}
    MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    MINIO_PORT: ${MINIO_PORT}
    MINIO_CONSOLE_PORT: ${MINIO_CONSOLE_PORT}
    MINIO_PUBLIC_URL: ${MINIO_PUBLIC_URL}
    QDRANT_PORT: ${QDRANT_PORT}
    UPTIME_KUMA_PORT: ${UPTIME_KUMA_PORT}
    DIRECTUS_API_URL: ${DIRECTUS_API_URL}
    DIRECTUS_API_TOKEN: ${DIRECTUS_API_TOKEN}
    LITELLM_API_URL: ${LITELLM_API_URL}
    LITELLM_API_KEY: ${LITELLM_API_KEY}
    BITRIX_PUBLICATION_API_URL: ${BITRIX_PUBLICATION_API_URL}
    BITRIX_PUBLICATION_API_TOKEN: ${BITRIX_PUBLICATION_API_TOKEN}
    TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
    TELEGRAM_CONTENT_CHAT_ID: ${TELEGRAM_CONTENT_CHAT_ID}

volumes:
  - name: postgres_data
  - name: redis_data
  - name: minio_data
  - name: qdrant_storage
  - name: directus_uploads
  - name: directus_extensions
  - name: n8n_data
  - name: openwebui_data
  - name: litellm_data
  - name: uptime_kuma_data
  - name: postgres_init

containers:
  - name: cf_postgres
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
      DIRECTUS_DB_NAME: ${DIRECTUS_DB_NAME}
      DIRECTUS_DB_USER: ${DIRECTUS_DB_USER}
      DIRECTUS_DB_PASSWORD: ${DIRECTUS_DB_PASSWORD}
      N8N_DB_NAME: ${N8N_DB_NAME}
      N8N_DB_USER: ${N8N_DB_USER}
      N8N_DB_PASSWORD: ${N8N_DB_PASSWORD}
      LITELLM_DB_NAME: ${LITELLM_DB_NAME}
      LITELLM_DB_USER: ${LITELLM_DB_USER}
      LITELLM_DB_PASSWORD: ${LITELLM_DB_PASSWORD}
    mounts:
      - volume: postgres_data
        target: /var/lib/postgresql/data
      - volume: postgres_init
        target: /docker-entrypoint-initdb.d
        read_only: true

  - name: cf_redis
    image: redis:7-alpine
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes", "--requirepass", "${REDIS_PASSWORD}"]
    mounts:
      - volume: redis_data
        target: /data

  - name: cf_minio
    image: minio/minio:latest
    restart: unless-stopped
    command: ["server", "/data", "--console-address", ":9001"]
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
      MINIO_BROWSER_REDIRECT_URL: ${MINIO_PUBLIC_URL}
    mounts:
      - volume: minio_data
        target: /data
    ports:
      - target: 9000
      - target: 9001

  - name: cf_qdrant
    image: qdrant/qdrant:latest
    restart: unless-stopped
    mounts:
      - volume: qdrant_storage
        target: /qdrant/storage
    ports:
      - target: 6333

  - name: cf_directus
    image: directus/directus:${DIRECTUS_VERSION}
    restart: unless-stopped
    depends_on:
      - cf_postgres
      - cf_redis
      - cf_minio
    environment:
      KEY: ${DIRECTUS_SECRET}
      SECRET: ${DIRECTUS_SECRET}
      ADMIN_EMAIL: ${DIRECTUS_ADMIN_EMAIL}
      ADMIN_PASSWORD: ${DIRECTUS_ADMIN_PASSWORD}
      PUBLIC_URL: ${DIRECTUS_PUBLIC_URL}
      CORS_ENABLED: "true"
      CORS_ORIGIN: ${DIRECTUS_CORS_ORIGIN}
      DB_CLIENT: pg
      DB_HOST: cf_postgres
      DB_PORT: 5432
      DB_DATABASE: ${DIRECTUS_DB_NAME}
      DB_USER: ${DIRECTUS_DB_USER}
      DB_PASSWORD: ${DIRECTUS_DB_PASSWORD}
      REDIS_ENABLED: "true"
      REDIS: redis://:${REDIS_PASSWORD}@cf_redis:6379
      WEBSOCKETS_ENABLED: "true"
      STORAGE_LOCATIONS: minio
      STORAGE_MINIO_DRIVER: s3
      STORAGE_MINIO_KEY: ${MINIO_ROOT_USER}
      STORAGE_MINIO_SECRET: ${MINIO_ROOT_PASSWORD}
      STORAGE_MINIO_BUCKET: directus
      STORAGE_MINIO_REGION: us-east-1
      STORAGE_MINIO_ENDPOINT: http://cf_minio:9000
      STORAGE_MINIO_FORCE_PATH_STYLE: "true"
    mounts:
      - volume: directus_uploads
        target: /directus/uploads
      - volume: directus_extensions
        target: /directus/extensions
    ports:
      - target: 8055

  - name: cf_n8n
    image: n8nio/n8n:${N8N_VERSION}
    restart: unless-stopped
    depends_on:
      - cf_postgres
      - cf_redis
      - cf_directus
    environment:
      N8N_HOST: ${N8N_HOST}
      N8N_PORT: ${N8N_PORT}
      N8N_PROTOCOL: https
      WEBHOOK_URL: ${N8N_WEBHOOK_URL}
      N8N_ENCRYPTION_KEY: ${N8N_ENCRYPTION_KEY}
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: cf_postgres
      DB_POSTGRESDB_PORT: 5432
      DB_POSTGRESDB_DATABASE: ${N8N_DB_NAME}
      DB_POSTGRESDB_USER: ${N8N_DB_USER}
      DB_POSTGRESDB_PASSWORD: ${N8N_DB_PASSWORD}
      QUEUE_BULL_REDIS_HOST: cf_redis
      QUEUE_BULL_REDIS_PORT: 6379
      QUEUE_BULL_REDIS_PASSWORD: ${REDIS_PASSWORD}
      N8N_RUNNERS_ENABLED: "true"
      N8N_METRICS: "true"
      DIRECTUS_API_URL: ${DIRECTUS_API_URL}
      DIRECTUS_API_TOKEN: ${DIRECTUS_API_TOKEN}
      LITELLM_API_URL: ${LITELLM_API_URL}
      LITELLM_API_KEY: ${LITELLM_API_KEY}
      BITRIX_PUBLICATION_API_URL: ${BITRIX_PUBLICATION_API_URL}
      BITRIX_PUBLICATION_API_TOKEN: ${BITRIX_PUBLICATION_API_TOKEN}
      TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
      TELEGRAM_CONTENT_CHAT_ID: ${TELEGRAM_CONTENT_CHAT_ID}
    mounts:
      - volume: n8n_data
        target: /home/node/.n8n
    ports:
      - target: 5678

  - name: cf_openwebui
    image: ghcr.io/open-webui/open-webui:${OPENWEBUI_VERSION}
    restart: unless-stopped
    depends_on:
      - cf_litellm
    environment:
      WEBUI_SECRET_KEY: ${OPENWEBUI_SECRET_KEY}
      OPENAI_API_BASE_URL: ${LITELLM_API_URL}
      OPENAI_API_KEY: ${LITELLM_API_KEY}
    mounts:
      - volume: openwebui_data
        target: /app/backend/data
    ports:
      - target: 3000

  - name: cf_litellm
    image: ghcr.io/berriai/litellm:main-latest
    restart: unless-stopped
    depends_on:
      - cf_postgres
    environment:
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
      DATABASE_URL: postgresql://${LITELLM_DB_USER}:${LITELLM_DB_PASSWORD}@cf_postgres:5432/${LITELLM_DB_NAME}
      UI_USERNAME: ${LITELLM_UI_USERNAME}
      UI_PASSWORD: ${LITELLM_UI_PASSWORD}
      OPENAI_API_KEY: ${OPENAI_API_KEY}
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
      GEMINI_API_KEY: ${GEMINI_API_KEY}
      GIGACHAT_API_KEY: ${GIGACHAT_API_KEY}
      YANDEXGPT_API_KEY: ${YANDEXGPT_API_KEY}
    mounts:
      - volume: litellm_data
        target: /app/data
    ports:
      - target: 4000

  - name: cf_uptime_kuma
    image: louislam/uptime-kuma:latest
    restart: unless-stopped
    mounts:
      - volume: uptime_kuma_data
        target: /app/data
    ports:
      - target: 3001

routes:
  - host: content.angstrem-mebel.ru
    container: cf_directus
    port: 8055
  - host: n8n-content.angstrem-mebel.ru
    container: cf_n8n
    port: 5678
  - host: ai-content.angstrem-mebel.ru
    container: cf_openwebui
    port: 3000
  - host: llm-content.angstrem-mebel.ru
    container: cf_litellm
    port: 4000
  - host: files-content.angstrem-mebel.ru
    container: cf_minio
    port: 9000
  - host: status-content.angstrem-mebel.ru
    container: cf_uptime_kuma
    port: 3001
